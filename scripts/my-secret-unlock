#!/usr/bin/env bash
set -euo pipefail

# ============================================================
# my-secret-unlock — Mount/unmount the encrypted vault triggered
# by successful QR challenge-response verification.
#
# Runs as root via sudo (NOPASSWD).
# Requires a one-time auth token passed as the first argument.
# The token is created by the QR auth Go program and expires
# after 5 seconds / single use.
#
# Without a valid token, this script refuses to execute —
# preventing manual bypass of the QR authentication.
#
# Vault layout:
#   ~/vault.encrypted/  — encrypted ciphertext (created by vault-setup.sh)
#   ~/vault/            — plaintext mount point (appears when unlocked)
#
# INSTALL:
#   sudo cp my-secret-unlock /usr/local/bin/my-secret-unlock
#   sudo chown root:root /usr/local/bin/my-secret-unlock
#   sudo chmod 0700 /usr/local/bin/my-secret-unlock
#   sudo visudo -f /etc/sudoers.d/qr-auth:
#     %wheel ALL=(root) NOPASSWD: /usr/local/bin/my-secret-unlock
# ============================================================

# ============================================================
# Token validation — prevents manual bypass of QR auth
# ============================================================

TOKEN_FILE="${1:-}"

if [ -z "$TOKEN_FILE" ]; then
    echo "ERROR: No auth token provided. This script requires QR authentication." >&2
    exit 1
fi

if [ ! -f "$TOKEN_FILE" ]; then
    echo "ERROR: Auth token file not found: $TOKEN_FILE" >&2
    exit 1
fi

# Token must be less than 5 seconds old
TOKEN_AGE=$(($(date +%s) - $(stat -c %Y "$TOKEN_FILE" 2>/dev/null || echo 0)))
if [ "$TOKEN_AGE" -gt 5 ]; then
    echo "ERROR: Auth token expired (${TOKEN_AGE}s old, max 5s). Re-authenticate via QR." >&2
    rm -f "$TOKEN_FILE"
    exit 1
fi

# Read and immediately consume the token (one-time use)
TOKEN=$(head -1 "$TOKEN_FILE" 2>/dev/null || true)
rm -f "$TOKEN_FILE"

if [ -z "$TOKEN" ] || [ ${#TOKEN} -lt 32 ]; then
    echo "ERROR: Invalid auth token." >&2
    exit 1
fi

# ============================================================
# Token valid — proceed with unlock action
# ============================================================

REAL_USER="${SUDO_USER:-$USER}"
REAL_HOME=$(eval echo "~${REAL_USER}")

VAULT_ENC="${REAL_HOME}/vault.encrypted"
VAULT_MNT="${REAL_HOME}/vault"
KEY_FILE="/root/.qr-vault-key"
UNLOCK_LOG="/var/log/qr-auth-unlock.log"

log() {
    echo "[$(date -Iseconds)] $*" | tee -a "$UNLOCK_LOG" >&2
}

if ! command -v gocryptfs &>/dev/null; then
    log "FATAL: gocryptfs not installed"
    exit 1
fi

if [ ! -f "$KEY_FILE" ]; then
    log "FATAL: key file $KEY_FILE not found — run vault-setup.sh first"
    exit 1
fi

if [ ! -d "$VAULT_ENC" ]; then
    log "FATAL: encrypted vault $VAULT_ENC not found — run vault-setup.sh first"
    exit 1
fi

if mountpoint -q "$VAULT_MNT" 2>/dev/null; then
    log "Unmounting vault at $VAULT_MNT..."
    fusermount -u "$VAULT_MNT"
    log "Vault unmounted (token: ${TOKEN:0:8}...)"
else
    log "Mounting vault at $VAULT_MNT..."
    mkdir -p "$VAULT_MNT"
    chown "${REAL_USER}:${REAL_USER}" "$VAULT_MNT" 2>/dev/null || true

    gocryptfs \
        -passfile "$KEY_FILE" \
        -allow_other \
        "$VAULT_ENC" "$VAULT_MNT"

    log "Vault mounted — $REAL_USER can access $VAULT_MNT (token: ${TOKEN:0:8}...)"
fi

exit 0
